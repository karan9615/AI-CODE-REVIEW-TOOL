# ==============================================
# GitLab MR AI Review - Backend Configuration
# ==============================================

# ----------------
# Server Configuration
# ----------------
# Port for the backend server (default: 3001)
PORT=3001

# Node environment: "development" or "production"
NODE_ENV=development

# ----------------
# Frontend Configuration
# ----------------
# IMPORTANT: URL of your frontend application
# Used for CORS configuration to allow cross-origin requests
#
# Local development:
# CLIENT_URL=http://localhost:5173
#
# Production (Netlify example):
# CLIENT_URL=https://your-app.netlify.app
#
# Production (custom domain):
# CLIENT_URL=https://yourdomain.com
#
# ⚠️  WARNING: This MUST match your actual frontend URL in production
# ⚠️  Do NOT include trailing slashes
CLIENT_URL=http://localhost:5173

# ----------------
# Session Security
# ----------------
# Secret key for encrypting session cookies
# IMPORTANT: Change this to a strong, random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=secure-session-key-change-me

# ----------------
# AI Provider API Keys
# ----------------
# OpenAI API Key (for ChatGPT models)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for Gemini models)
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------
# Deployment Notes
# ----------------
# When deploying to Render (or similar platforms):
#
# 1. Set CLIENT_URL to your Netlify/Vercel/production frontend URL
#    Example: https://code-review-ai-tool.netlify.app
#
# 2. Set NODE_ENV to "production"
#
# 3. Generate and set a strong SESSION_SECRET
#
# 4. Ensure your platform uses HTTPS (required for secure cookies)
#
# 5. After deployment, test the /api/health endpoint to verify configuration:
#    curl https://your-backend.onrender.com/api/health
#
# The health endpoint will show:
#   - Current CLIENT_URL being used
#   - Cookie settings (secure, sameSite)
#   - Environment mode
